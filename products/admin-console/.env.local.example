# ============================================
# AuthFusion Admin Console - 환경 변수 설정
# ============================================

# SSO Server URL
SSO_SERVER_URL=http://localhost:8081
NEXT_PUBLIC_SSO_SERVER_URL=http://localhost:8081

# NextAuth 설정 (OIDC 연동 시)
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32

# SSO Server 클라이언트 (OIDC 연동 시)
SSO_CLIENT_ID=admin-console
SSO_CLIENT_SECRET=your-client-secret-here

# 앱 설정
NEXT_PUBLIC_APP_NAME=AuthFusion Admin Console
NEXT_PUBLIC_APP_VERSION=1.0.0
